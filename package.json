{
  "name": "deepseek-monitor",
  "version": "1.1.0",
  "description": "DeepSeek API 实时用量监控仪表板",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -n renderer,electron -c blue,green \"vite\" \"npm run build:main && wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.node.json",
    "build": "npm run build:renderer && npm run build:main",
    "start": "electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "build": {
    "appId": "com.deepseek.monitor",
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "productName": "Claude-DeepSeek Monitor",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "config.yaml"
    ],
    "extraResources": [
      {
        "from": "data",
        "to": "data"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "installer.nsh"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": "AppImage",
      "category": "Development"
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^11.7.0",
    "csv-parse": "^6.2.1",
    "js-yaml": "^4.1.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.17.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "lucide-react": "^0.460.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.14.0",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0",
    "zustand": "^5.0.0"
  }
}
